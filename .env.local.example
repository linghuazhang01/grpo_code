# Copy this file to .env.local and keep the copied file private.
# The launcher exports these values only to the training subprocess.
export WANDB_API_KEY=
export WANDB_MODE=online

# Optional: set this when runs should be logged under a W&B team/entity.
# export WANDB_ENTITY=

# Optional: 141 GB launch profiles persist these beside checkpoints automatically.
# export WANDB_RUN_ID=
# export WANDB_RESUME=allow
